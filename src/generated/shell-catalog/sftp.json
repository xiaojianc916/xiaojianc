{
  "names": [
    "sftp"
  ],
  "detail": "OpenSSH secure file transfer",
  "args": [
    {
      "label": "sources",
      "detail": "File or directory, local or remote ([user@]host:[path])",
      "isVariadic": true
    },
    {
      "label": "target",
      "detail": "File or directory, local or remote ([user@]host:[path])"
    }
  ],
  "flags": [
    {
      "names": [
        "--help",
        "-h"
      ],
      "detail": "Show help for sftp"
    },
    {
      "names": [
        "-4"
      ],
      "detail": "Forces scp to use IPv4 addresses only"
    },
    {
      "names": [
        "-6"
      ],
      "detail": "Forces scp to use IPv6 addresses only"
    },
    {
      "names": [
        "-A"
      ],
      "detail": "Allows forwarding of ssh-agent(1) to the remote system. The default is not to forward an authentication agent"
    },
    {
      "names": [
        "-a"
      ],
      "detail": "Attempt to continue interrupted transfers rather than overwriting existing partial or complete copies of files. If the partial contents differ from those being transferred, then the resultant file is likely to be corrupt"
    },
    {
      "names": [
        "-B"
      ],
      "detail": "Specify the size of the buffer that sftp uses when transferring files. Larger buffers require fewer round trips at the cost of higher memory consumption. The default is 32768 bytes",
      "arg": {
        "label": "buffer_size",
        "detail": "The buffer size",
        "suggestions": [
          {
            "names": [
              "32768"
            ]
          }
        ]
      }
    },
    {
      "names": [
        "-b"
      ],
      "detail": "Batch mode reads a series of commands from an input batchfile instead of stdin. Since it lacks user interaction it should be used in conjunction with non-interactive authentication to obviate the need to enter a password at connection time (see sshd(8) and ssh-keygen(1) for details)",
      "arg": {
        "label": "batchfile",
        "detail": "The batch file"
      }
    },
    {
      "names": [
        "-C"
      ],
      "detail": "Compression enable. Passes the -C flag to ssh(1) to enable compression"
    },
    {
      "names": [
        "-c"
      ],
      "detail": "Selects the cipher to use for encrypting the data transfer. This option is directly passed to ssh(1)",
      "arg": {
        "label": "cipher",
        "detail": "The selected cipher specification"
      }
    },
    {
      "names": [
        "-D"
      ],
      "detail": "Connect directly to a local sftp server (rather than via ssh(1)). This option may be useful in debugging the client and server",
      "arg": {
        "label": "sftp_server_path",
        "detail": "Path to the SFTP server"
      }
    },
    {
      "names": [
        "-F"
      ],
      "detail": "Specifies an alternative per-user configuration file for ssh. This option is directly passed to ssh(1)",
      "arg": {
        "label": "ssh_config",
        "detail": "The selected ssh config"
      }
    },
    {
      "names": [
        "-f"
      ],
      "detail": "Requests that files be flushed to disk immediately after transfer"
    },
    {
      "names": [
        "-i"
      ],
      "detail": "Selects the file from which the identity (private key) for public key authentication is read. This option is directly passed to ssh(1)",
      "arg": {
        "label": "identity_file",
        "detail": "Specified identity file"
      }
    },
    {
      "names": [
        "-J"
      ],
      "detail": "Connect to the target host by first making an scp connection to the jump host described by destination and then establishing a TCP forwarding to the ultimate destination from there. Multiple jump hops may be specified separated by comma characters. This is a shortcut to specify a ProxyJump configuration directive. This option is directly passed to ssh(1)",
      "arg": {
        "label": "destination",
        "detail": "Scp destination"
      }
    },
    {
      "names": [
        "-l"
      ],
      "detail": "Limits the used bandwidth, specified in Kbit/s",
      "arg": {
        "label": "limit",
        "detail": "Limit bandwidth in Kbit/s"
      }
    },
    {
      "names": [
        "-N"
      ],
      "detail": "Disables quiet mode, e.g. to override the implicit quiet mode set by the -b flag"
    },
    {
      "names": [
        "-o"
      ],
      "detail": "Can be used to pass options to ssh in the format used in ssh_config(5). This is useful for specifying options for which there is no separate scp command-line flag. For full details of the options listed below, and their possible values, see ssh_config(5)",
