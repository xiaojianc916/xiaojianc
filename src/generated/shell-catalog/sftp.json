    {
      "names": [
        "-P"
      ],
      "detail": "Specifies the port to connect to on the remote host. Note that this option is written with a capital ‘P’, because -p is already reserved for preserving the times and modes of the file",
      "arg": {
        "label": "port"
      }
    },
    {
      "names": [
        "-p"
      ],
      "detail": "Preserves modification times, access times, and modes from the original file"
    },
    {
      "names": [
        "-q"
      ],
      "detail": "Quiet mode: disables the progress meter as well as warning and diagnostic messages from ssh(1)"
    },
    {
      "names": [
        "-R"
      ],
      "detail": "Specify how many requests may be outstanding at any one time. Increasing this may slightly improve file transfer speed but will increase memory usage. The default is 64 outstanding requests",
      "arg": {
        "label": "num_requests",
        "detail": "The number of requests",
        "suggestions": [
          {
            "names": [
              "64"
            ]
          }
        ]
      }
    },
    {
      "names": [
        "-r"
      ],
      "detail": "Recursively copy entire directories. Note that scp follows symbolic links encountered in the tree traversal"
    },
    {
      "names": [
        "-S"
      ],
      "detail": "Name of program to use for the encrypted connection. The program must understand ssh(1) options",
      "arg": {
        "label": "program"
      }
    },
    {
      "names": [
        "-s"
      ],
      "detail": "Specifies the SSH2 subsystem or the path for an sftp server on the remote host. A path is useful when the remote sshd(8) does not have an sftp subsystem configured",
      "arg": {
        "label": "subsystem | sftp_server",
        "detail": "Path to the SFTP server"
      }
    },
    {
      "names": [
        "-v"
      ],
      "detail": "Verbose mode. Causes scp and ssh(1) to print debugging messages about their progress. This is helpful in debugging connection, authentication, and configuration problems"
    }
