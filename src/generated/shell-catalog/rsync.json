        "-v",
        "--verbose"
      ],
      "detail": "Increase verbosity"
    },
    {
      "names": [
        "--info"
      ],
      "detail": "Fine-grained informational verbosity",
      "args": [
        {
          "label": "BACKUP",
          "detail": "Mention files backed up"
        },
        {
          "label": "COPY",
          "detail": "Mention files copied locally on the receiving side"
        },
        {
          "label": "DEL",
          "detail": "Mention deletions on the receiving side"
        },
        {
          "label": "FLIST",
          "detail": "Mention file-list receiving/sending (levels 1-2)"
        },
        {
          "label": "MISC",
          "detail": "Mention miscellaneous information (levels 1-2)"
        },
        {
          "label": "MOUNT",
          "detail": "Mention mounts that were found or skipped"
        },
        {
          "label": "NAME",
          "detail": "Mention 1) updated file/dir names, 2) unchanged names"
        },
        {
          "label": "PROGRESS",
          "detail": "Mention 1) per-file progress or 2) total transfer progress"
        },
        {
          "label": "REMOVE",
          "detail": "Mention files removed on the sending side"
        },
        {
          "label": "SKIP",
          "detail": "Mention files that are skipped due to options used"
        },
        {
          "label": "STATS",
          "detail": "Mention statistics at end of run (levels 1-3)"
        },
        {
          "label": "SYMSAFE",
          "detail": "Mention symlinks that are unsafe"
        },
        {
          "label": "ALL",
          "detail": "Set all --info options (e.g. all4)"
        },
        {
          "label": "NONE",
          "detail": "Silence all --info options (same as all0)"
        },
        {
          "label": "HELP",
          "detail": "Output this help message"
