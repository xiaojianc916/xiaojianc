{
  "names": [
    "htop"
  ],
  "detail": "Improved top (interactive process viewer)",
  "flags": [
    {
      "names": [
        "--help",
        "-h"
      ],
      "detail": "Show help for htop"
    },
    {
      "names": [
        "--no-color",
        "-C"
      ],
      "detail": "Use a monochrome color scheme"
    },
    {
      "names": [
        "--delay",
        "-d"
      ],
      "detail": "Delay between updates, in tenths of sec",
      "arg": {
        "label": "delay",
        "suggestions": [
          {
            "names": [
              "10"
            ]
          },
          {
            "names": [
              "1"
            ]
          },
          {
            "names": [
              "60"
            ]
          }
        ]
      }
    },
    {
      "names": [
        "--filter",
        "-F"
      ],
      "detail": "Filter commands",
      "arg": {
        "label": "filter"
      }
    },
    {
      "names": [
        "--highlight-changes",
        "-H"
      ],
      "detail": "Highlight new and old processes",
      "arg": {
        "label": "delay",
        "detail": "Delay between updates of highlights, in tenths of sec",
        "isOptional": true,
        "suggestions": [
          {
            "names": [
              "10"
            ]
          },
          {
            "names": [
              "1"
            ]
          },
          {
            "names": [
              "60"
            ]
          }
        ]
      }
    },
    {
      "names": [
        "--no-mouse",
        "-M"
      ],
      "detail": "Disable the mouse"
    },
    {
      "names": [
        "--pid",
        "-p"
      ],
      "detail": "Show only the given PIDs",
      "arg": {
        "label": "PID",
        "isVariadic": true
      }
    },
    {
      "names": [
        "--sort-key",
        "-s"
      ],
      "detail": "Sort by COLUMN in list view",
      "arg": {
        "label": "column"
      }
    },
    {
      "names": [
        "--tree",
        "-t"
      ],
      "detail": "Show the tree view"
    },
    {
      "names": [
        "--user",
        "-u"
      ],
      "detail": "Show only processes for a given user (or $USER)",
      "arg": {
        "label": "user",
        "isOptional": true,
        "suggestions": [
          {
            "names": [
              "$USER"
            ]
          }
        ]
      }
    },
    {
      "names": [
        "--no-unicode",
        "-U"
      ],
      "detail": "Do not use unicode but plain ASCII"
    },
    {
      "names": [
        "--version",
        "-V"
      ],
      "detail": "Print version info"
    }
  ]
}
