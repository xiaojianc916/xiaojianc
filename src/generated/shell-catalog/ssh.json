{
  "names": [
    "ssh"
  ],
  "detail": "Log into a remote machine",
  "args": [
    {
      "label": "user@hostname",
      "detail": "Address of remote machine to log into"
    }
  ],
  "flags": [
    {
      "names": [
        "-1"
      ],
      "detail": "Forces ssh to try protocol version 1 only"
    },
    {
      "names": [
        "-2"
      ],
      "detail": "Forces ssh to try protocol version 2 only"
    },
    {
      "names": [
        "-4"
      ],
      "detail": "Forces ssh to use IPv4 addresses only"
    },
    {
      "names": [
        "-6"
      ],
      "detail": "Forces ssh to use IPv6 addresses only"
    },
    {
      "names": [
        "-A"
      ],
      "detail": "Enables forwarding of the authentication agent connection"
    },
    {
      "names": [
        "-a"
      ],
      "detail": "Disables forwarding of the authentication agent connection"
    },
    {
      "names": [
        "-b"
      ],
      "detail": "Use bind_address on the local machine as the source address of the connection",
      "arg": {
        "label": "bind address",
        "detail": "Source address of the connection"
      }
    },
    {
      "names": [
        "-C"
      ],
      "detail": "Requests compression of all data (including stdin, stdout, stderr, and data for forwarded X11 and TCP connections)"
    },
    {
      "names": [
        "-c"
      ],
      "detail": "Selects the cipher specification for encrypting the session",
      "arg": {
        "label": "cipher spec",
        "detail": "The selected cipher specification"
      }
    },
    {
      "names": [
        "-D"
      ],
      "detail": "Specifies a local 'dynamic' application-level port forwarding",
      "arg": {
        "label": "port",
        "detail": "Port of the bind address"
      }
    },
    {
      "names": [
        "-e"
      ],
      "detail": "Sets the escape character for sessions with a pty (default: '~')",
      "arg": {
        "label": "escape char",
        "detail": "Specified escape character"
      }
    },
    {
      "names": [
        "-F"
      ],
      "detail": "Specifies an alternative per-user configuration file",
      "arg": {
        "label": "configfile",
        "detail": "Path to alternative config file"
      }
    },
    {
      "names": [
        "-f"
      ],
      "detail": "Requests ssh to go to background just before command execution"
    },
    {
      "names": [
        "-g"
      ],
      "detail": "Allows remote hosts to connect to local forwarded ports"
    },
    {
      "names": [
        "-I"
      ],
      "detail": "Specify the PKCS#11 shared library ssh should use to communicate with a PKCS#11 token providing the user's private RSA key",
      "arg": {
        "label": "pkcs11"
      }
    },
    {
      "names": [
        "-i"
      ],
      "detail": "Selects a file from which the identity (private key) for public key authentication is read",
      "arg": {
        "label": "identity file",
        "detail": "Path to identity (private key)"
      }
    },
    {
      "names": [
        "-K"
      ],
      "detail": "Enables GSSAPI-based authentication and forwarding (delegation) of GSSAPI credentials to the server"
    },
    {
      "names": [
        "-k"
      ],
      "detail": "Disables forwarding (delegation) of GSSAPI credentials to the server"
    },
    {
      "names": [
        "-L"
      ],
      "detail": "Specifies that the given port on the local (client) host is to be forwarded to the given host and port on the remote side",
      "arg": {
        "label": "port:host:hostport",
        "detail": "Local port, followed by host and host port to forward to"
      }
    },
    {
      "names": [
        "-l"
      ],
      "detail": "Specifies the user to log in as on the remote machine",
      "arg": {
        "label": "login name",
        "detail": "Name of user logging into remote machine"
      }
    },
    {
      "names": [
        "-M"
      ],
      "detail": "Places the ssh client into ``master'' mode for connection sharing"
    },
    {
      "names": [
        "-m"
      ],
      "detail": "Additionally, for protocol version 2 a comma-separated list of MAC (message authentication code) algorithms can be specified in order of preference",
      "arg": {
        "label": "mac spec"
      }
    },
    {
      "names": [
        "-N"
      ],
      "detail": "Do not execute a remote command"
    },
    {
      "names": [
        "-n"
      ],
      "detail": "Redirects stdin from /dev/null (actually, prevents reading from stdin)"
    },
    {
      "names": [
        "-O"
      ],
      "detail": "Control an active connection multiplexing master process",
      "arg": {
        "label": "ctl cmd",
        "detail": "Command that's passed to the master process"
      }
    },
