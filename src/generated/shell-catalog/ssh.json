    {
      "names": [
        "-p"
      ],
      "detail": "Port to connect to on the remote host",
      "arg": {
        "label": "port",
        "detail": "Port to connect to"
      }
    },
    {
      "names": [
        "-q"
      ],
      "detail": "Quiet mode. Causes most warning and diagnostic messages to be suppressed"
    },
    {
      "names": [
        "-R"
      ],
      "detail": "Specifies that the given port on the remote (server) host is to be forwarded to the given host and port on the local side",
      "arg": {
        "label": "port:host:hostport",
        "detail": "Local port, followed by host and host port to forward to"
      }
    },
    {
      "names": [
        "-S"
      ],
      "detail": "Specifies the location of a control socket for connection sharing, or the string 'none' to disable connection sharing",
      "arg": {
        "label": "ctl_path",
        "detail": "Location of the control socket"
      }
    },
    {
      "names": [
        "-s"
      ],
      "detail": "May be used to request invocation of a subsystem on the remote system"
    },
    {
      "names": [
        "-T"
      ],
      "detail": "Disable pseudo-tty allocation"
    },
    {
      "names": [
        "-t"
      ],
      "detail": "Force pseudo-tty allocation"
    },
    {
      "names": [
        "-V"
      ],
      "detail": "Display the version number and exit"
    },
    {
      "names": [
        "-v"
      ],
      "detail": "Verbose mode. Causes ssh to print debugging messages about its progress"
    },
    {
      "names": [
        "-W"
      ],
      "detail": "Requests that standard input and output on the client be forwarded to host on port over the secure channel",
      "arg": {
        "label": "host:port",
        "detail": "Host and port to forward to"
      }
    },
    {
      "names": [
        "-w"
      ],
      "detail": "Requests tunnel device forwarding with the specified tun(4) devices between the client (local_tun) and the server (remote_tun)",
      "arg": {
        "label": "local tun",
        "detail": "Local device to forward to"
      }
    },
    {
      "names": [
        "-X"
      ],
      "detail": "Enables X11 forwarding"
    },
    {
      "names": [
        "-x"
      ],
      "detail": "Disables X11 forwarding"
    },
    {
      "names": [
        "-Y"
      ],
      "detail": "Enables trusted X11 forwarding"
    },
    {
      "names": [
        "-y"
      ],
      "detail": "Send log information using the syslog(3) system module"
    }
  ]
