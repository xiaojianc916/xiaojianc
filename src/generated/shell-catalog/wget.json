{
  "names": [
    "wget"
  ],
  "detail": "A non-interactive network retriever",
  "args": [
    {
      "label": "url",
      "detail": "The url(s) to retrieve",
      "isVariadic": true
    }
  ],
  "flags": [
    {
      "names": [
        "-V",
        "--version"
      ],
      "detail": "Display the version of Wget and exit"
    },
    {
      "names": [
        "-h",
        "--help"
      ],
      "detail": "Print this help"
    },
    {
      "names": [
        "-b",
        "--background"
      ],
      "detail": "Go to background after startup"
    },
    {
      "names": [
        "-e",
        "--execute=COMMAND"
      ],
      "detail": "Execute a `.wgetrc'-style command"
    },
    {
      "names": [
        "-o",
        "--output-file=FILE"
      ],
      "detail": "Log messages to FILE"
    },
    {
      "names": [
        "-a",
        "--append-output=FILE"
      ],
      "detail": "Append messages to FILE"
    },
    {
      "names": [
        "-q",
        "--quiet"
      ],
      "detail": "Quiet (no output)"
    },
    {
      "names": [
        "-v",
        "--verbose"
      ],
      "detail": "Be verbose (this is the default)"
    },
    {
      "names": [
        "-nv",
        "--no-verbose"
      ],
      "detail": "Turn off verboseness, without being quiet"
    },
    {
      "names": [
        "--report-speed=TYPE"
      ],
      "detail": "Output bandwidth as TYPE. TYPE can be bits"
    },
    {
      "names": [
        "-i",
        "--input-file=FILE"
      ],
      "detail": "Download URLs found in local or external FILE"
    },
    {
      "names": [
        "-F",
        "--force-html"
      ],
      "detail": "Treat input file as HTML"
    },
    {
      "names": [
        "-B",
        "--base=URL"
      ],
      "detail": "Resolves HTML input-file links (-i -F) relative to URL"
    },
    {
      "names": [
        "--config=FILE"
      ],
      "detail": "Specify config file to use"
    },
    {
      "names": [
        "--no-config"
      ],
      "detail": "Do not read any config file"
    },
    {
      "names": [
        "--rejected-log=FILE"
      ],
      "detail": "Log reasons for URL rejection to FILE"
    },
    {
      "names": [
        "-t",
        "--tries=NUMBER"
      ],
      "detail": "Set number of retries to NUMBER (0 unlimits)"
    },
    {
      "names": [
        "--retry-connrefused"
      ],
      "detail": "Retry even if connection is refused"
    },
    {
      "names": [
        "--retry-on-http-error"
      ],
      "detail": "Comma-separated list of HTTP errors to retry"
    },
    {
      "names": [
        "-O",
        "--output-document=FILE"
      ],
      "detail": "Write documents to FILE"
    },
    {
      "names": [
        "-nc",
        "--no-clobber"
      ],
      "detail": "Skip downloads that would download to existing files (overwriting them)"
    },
    {
      "names": [
        "--no-netrc"
      ],
      "detail": "Don't try to obtain credentials from .netrc"
    },
    {
      "names": [
        "-c",
        "--continue"
      ],
      "detail": "Resume getting a partially-downloaded file"
    },
    {
      "names": [
        "--start-pos=OFFSET"
      ],
      "detail": "Start downloading from zero-based position OFFSET"
    },
    {
      "names": [
        "--progress=TYPE"
      ],
      "detail": "Select progress gauge type"
    },
    {
      "names": [
        "--show-progress"
      ],
      "detail": "Display the progress bar in any verbosity mode"
    },
    {
      "names": [
        "-N",
        "--timestamping"
      ],
      "detail": "Don't re-retrieve files unless newer than local"
    },
    {
      "names": [
        "-S",
        "--server-response"
      ],
      "detail": "Print server response"
    },
    {
      "names": [
        "--spider"
      ],
      "detail": "Don't download anything"
    },
    {
      "names": [
        "-T",
        "--timeout=SECONDS"
      ],
      "detail": "Set all timeout values to SECONDS"
    },
    {
      "names": [
        "--dns-timeout=SECS"
      ],
      "detail": "Set the DNS lookup timeout to SECS"
    },
    {
      "names": [
        "--connect-timeout=SECS"
      ],
      "detail": "Set the connect timeout to SECS"
    },
    {
      "names": [
        "--read-timeout=SECS"
      ],
      "detail": "Set the read timeout to SECS"
    },
    {
      "names": [
        "-w",
        "--wait=SECONDS"
      ],
      "detail": "Wait SECONDS between retrievals"
    },
    {
      "names": [
        "--waitretry=SECONDS"
      ],
      "detail": "Wait 1..SECONDS between retries of a retrieval"
    },
    {
      "names": [
        "--random-wait"
      ],
      "detail": "Wait from 0.5*WAIT...1.5*WAIT secs between retrievals"
    },
    {
      "names": [
        "--no-proxy"
      ],
      "detail": "Explicitly turn off proxy"
    },
    {
      "names": [
        "-Q",
        "--quota=NUMBER"
      ],
      "detail": "Set retrieval quota to NUMBER"
    },
    {
      "names": [
        "--bind-address=ADDRESS"
      ],
      "detail": "Bind to ADDRESS (hostname or IP) on local host"
    },
    {
      "names": [
        "--limit-rate=RATE"
      ],
      "detail": "Limit download rate to RATE"
    },
    {
      "names": [
        "--no-dns-cache"
      ],
      "detail": "Disable caching DNS lookups"
    },
    {
      "names": [
        "--restrict-file-names=OS"
      ],
      "detail": "Restrict chars in file names to ones OS allows"
    },
    {
      "names": [
        "--ignore-case"
      ],
      "detail": "Ignore case when matching files/directories"
    },
    {
      "names": [
        "-4",
        "--inet4-only"
      ],
      "detail": "Connect only to IPv4 addresses"
    },
    {
      "names": [
        "-6",
        "--inet6-only"
      ],
      "detail": "Connect only to IPv6 addresses"
    },
    {
      "names": [
        "--user=USER"
      ],
      "detail": "Set both ftp and http user to USER"
    },
    {
      "names": [
        "--password=PASS"
      ],
      "detail": "Set both ftp and http password to PASS"
    },
    {
      "names": [
        "--ask-password"
      ],
      "detail": "Prompt for passwords"
    },
    {
      "names": [
        "--no-iri"
      ],
      "detail": "Turn off IRI support"
    },
    {
      "names": [
        "--local-encoding=ENC"
      ],
      "detail": "Use ENC as the local encoding for IRIs"
    },
    {
      "names": [
        "--remote-encoding=ENC"
      ],
      "detail": "Use ENC as the default remote encoding"
    },
    {
      "names": [
        "--unlink"
      ],
      "detail": "Remove file before clobber"
    },
    {
      "names": [
        "--xattr"
      ],
      "detail": "Turn on storage of metadata in extended file attributes"
    },
    {
      "names": [
        "-nd",
        "--no-directories"
      ],
      "detail": "Don't create directories"
    },
    {
      "names": [
        "-x",
        "--force-directories"
      ],
      "detail": "Force creation of directories"
    },
    {
      "names": [
        "-nH",
        "--no-host-directories"
      ],
      "detail": "Don't create host directories"
    },
    {
      "names": [
        "--protocol-directories"
      ],
      "detail": "Use protocol name in directories"
    },
    {
      "names": [
        "-P",
        "--directory-prefix=PREFIX"
      ],
      "detail": "Save files to PREFIX/"
    },
    {
      "names": [
        "--cut-dirs=NUMBER"
      ],
      "detail": "Ignore NUMBER remote directory components"
    },
    {
      "names": [
        "--http-user=USER"
      ],
      "detail": "Set http user to USER"
    },
    {
      "names": [
        "--http-password=PASS"
      ],
      "detail": "Set http password to PASS"
    },
    {
      "names": [
        "--no-cache"
      ],
      "detail": "Disallow server-cached data"
    },
    {
      "names": [
        "-E",
        "--adjust-extension"
      ],
      "detail": "Save HTML/CSS documents with proper extensions"
    },
    {
      "names": [
        "--ignore-length"
      ],
      "detail": "Ignore 'Content-Length' header field"
    },
    {
      "names": [
        "--header=STRING"
      ],
      "detail": "Insert STRING among the headers"
    },
    {
      "names": [
        "--compression=TYPE"
      ],
      "detail": "Choose compression, one of auto, gzip and none. (default: none)"
    },
    {
      "names": [
        "--max-redirect"
      ],
      "detail": "Maximum redirections allowed per page"
    },
    {
      "names": [
        "--proxy-user=USER"
      ],
      "detail": "Set USER as proxy username"
    },
    {
      "names": [
        "--proxy-password=PASS"
      ],
      "detail": "Set PASS as proxy password"
    },
    {
      "names": [
        "--referer=URL"
      ],
      "detail": "Include 'Referer: URL' header in HTTP request"
    },
    {
      "names": [
        "--save-headers"
      ],
      "detail": "Save the HTTP headers to file"
    },
    {
      "names": [
        "-U",
        "--user-agent=AGENT"
      ],
      "detail": "Identify as AGENT instead of Wget/VERSION"
    },
    {
      "names": [
        "--no-http-keep-alive"
      ],
      "detail": "Disable HTTP keep-alive (persistent connections)"
    },
    {
      "names": [
        "--no-cookies"
      ],
      "detail": "Don't use cookies"
    },
    {
      "names": [
        "--load-cookies=FILE"
      ],
      "detail": "Load cookies from FILE before session"
    },
    {
      "names": [
        "--save-cookies=FILE"
      ],
      "detail": "Save cookies to FILE after session"
    },
    {
      "names": [
        "--keep-session-cookies"
      ],
      "detail": "Load and save session (non-permanent) cookies"
    },
    {
      "names": [
        "--post-data=STRING"
      ],
      "detail": "Use the POST method; send STRING as the data"
    },
    {
      "names": [
        "--post-file=FILE"
      ],
      "detail": "Use the POST method; send contents of FILE"
    },
    {
      "names": [
        "--method=HTTPMethod"
      ],
      "detail": "Use method \"HTTPMethod\" in the request"
    },
    {
      "names": [
        "--body-data=STRING"
      ],
      "detail": "Send STRING as data. --method MUST be set"
    },
    {
      "names": [
        "--body-file=FILE"
      ],
      "detail": "Send contents of FILE. --method MUST be set"
    },
    {
      "names": [
        "--content-on-error"
      ],
      "detail": "Output the received content on server errors"
    },
    {
      "names": [
        "--secure-protocol=PR"
      ],
      "detail": "Choose secure protocol, one of auto, SSLv2,"
    },
    {
      "names": [
        "--https-only"
      ],
      "detail": "Only follow secure HTTPS links"
    },
    {
      "names": [
        "--no-check-certificate"
      ],
      "detail": "Don't validate the server's certificate"
    },
    {
      "names": [
        "--certificate=FILE"
      ],
      "detail": "Client certificate file"
    },
    {
      "names": [
        "--certificate-type=TYPE"
      ],
      "detail": "Client certificate type, PEM or DER"
    },
    {
      "names": [
        "--private-key=FILE"
      ],
      "detail": "Private key file"
    },
    {
      "names": [
        "--private-key-type=TYPE"
      ],
      "detail": "Private key type, PEM or DER"
    },
    {
      "names": [
        "--ca-certificate=FILE"
      ],
      "detail": "File with the bundle of CAs"
    },
    {
      "names": [
        "--ca-directory=DIR"
      ],
      "detail": "Directory where hash list of CAs is stored"
    },
    {
      "names": [
        "--crl-file=FILE"
      ],
      "detail": "File with bundle of CRLs"
    },
    {
      "names": [
        "--ciphers=STR"
      ],
      "detail": "Set the priority string (GnuTLS) or cipher list string (OpenSSL) directly"
    },
    {
      "names": [
        "-r",
        "--recursive"
      ],
      "detail": "Specify recursive download"
    },
    {
      "names": [
        "-l",
        "--level=NUMBER"
      ],
      "detail": "Maximum recursion depth (inf or 0 for infinite)"
    },
    {
      "names": [
        "--delete-after"
      ],
      "detail": "Delete files locally after downloading them"
    },
    {
      "names": [
        "-k",
        "--convert-links"
      ],
      "detail": "Make links in downloaded HTML or CSS point to local files"
    },
    {
      "names": [
        "-K",
        "--backup-converted"
      ],
      "detail": "Before converting file X, back up as X.orig"
    },
    {
      "names": [
        "-m",
        "--mirror"
      ],
      "detail": "Shortcut for -N -r -l inf --no-remove-listing"
    },
    {
      "names": [
        "-p",
        "--page-requisites"
      ],
      "detail": "Get all images, etc. needed to display HTML page"
    },
    {
      "names": [
        "-A",
        "--accept=LIST"
      ],
      "detail": "Comma-separated list of accepted extensions"
    },
    {
      "names": [
        "-R",
        "--reject=LIST"
      ],
      "detail": "Comma-separated list of rejected extensions"
    },
    {
      "names": [
        "--accept-regex=REGEX"
      ],
      "detail": "Regex matching accepted URLs"
    },
    {
      "names": [
        "--reject-regex=REGEX"
      ],
      "detail": "Regex matching rejected URLs"
    },
    {
      "names": [
        "--regex-type=TYPE"
      ],
      "detail": "Regex type (posix)"
    },
    {
      "names": [
        "-D",
        "--domains=LIST"
      ],
      "detail": "Comma-separated list of accepted domains"
    },
    {
      "names": [
        "--exclude-domains=LIST"
      ],
      "detail": "Comma-separated list of rejected domains"
    },
    {
      "names": [
        "--follow-ftp"
      ],
      "detail": "Follow FTP links from HTML documents"
    },
    {
      "names": [
        "--follow-tags=LIST"
      ],
      "detail": "Comma-separated list of followed HTML tags"
    },
    {
      "names": [
        "--ignore-tags=LIST"
      ],
      "detail": "Comma-separated list of ignored HTML tags"
    },
    {
      "names": [
        "-H",
        "--span-hosts"
      ],
      "detail": "Go to foreign hosts when recursive"
    },
    {
      "names": [
        "-L",
        "--relative"
      ],
      "detail": "Follow relative links only"
    },
    {
      "names": [
        "-I",
        "--include-directories=LIST"
      ],
      "detail": "List of allowed directories"
    },
    {
      "names": [
        "-X",
        "--exclude-directories=LIST"
      ],
      "detail": "List of excluded directories"
    },
    {
      "names": [
        "-np",
        "--no-parent"
      ],
      "detail": "Don't ascend to the parent directory"
    }
  ]
}
