{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SH 编辑器",
  "version": "0.1.0",
  "identifier": "com.xiaojianc.sh-editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SH 编辑器",
        "width": 1500,
        "height": 960,
        "minWidth": 1220,
        "minHeight": 760,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis"
  }
}
