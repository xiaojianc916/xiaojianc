{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SH 编辑器",
  "version": "0.1.0",
  "identifier": "com.xiaojianc.sh-editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SH 编辑器",
        "width": 1500,
        "height": 960,
        "minWidth": 1220,
        "minHeight": 760,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true,
        "center": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "xiaojianc",
    "copyright": "© 2026 xiaojianc",
    "category": "DeveloperTool",
    "shortDescription": "面向 WSL2 的 Shell 脚本编辑器",
    "longDescription": "SH 编辑器：在 Windows 上以原生体验编写、格式化、诊断并运行 Shell 脚本，执行环境统一由 WSL2 驱动。",
    "fileAssociations": [
      {
        "ext": [
          "sh",
          "bash"
        ],
        "name": "Shell Script",
        "description": "Shell 脚本文件",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/app-generated.ico"
    ]
  }
}