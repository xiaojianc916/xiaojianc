{
  "name": "sh-editor-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:env": "node ./scripts/check-dev-env.mjs",
    "wsl-link:agent:build": "node ./scripts/build-wsl-link-agent.mjs",
    "generate:shell-catalog": "node ./scripts/generate-shell-command-catalog.mjs",
    "dev": "npm run generate:shell-catalog && vite --host 0.0.0.0 --port 1420",
    "pretauri:dev": "node ./scripts/check-dev-env.mjs",
    "build": "npm run generate:shell-catalog && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue",
    "typecheck": "vue-tsc --noEmit",
    "size-limit": "npm run build && size-limit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "guard": "node_modules/.bin/tsx scripts/run-all-guards.ts",
    "tauri": "node ./scripts/run-tauri.mjs",
    "tauri:dev": "node ./scripts/run-tauri.mjs dev",
    "tauri:build": "node ./scripts/run-tauri.mjs build",
    "prepare": "husky"
  },
  "dependencies": {
    "@formkit/auto-animate": "0.9.0",
    "@icon-park/vue-next": "^1.4.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@vueuse/core": "^14.3.0",
    "@wasm-fmt/shfmt": "^0.2.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.175",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "lucide-vue-next": "^1.0.0",
    "markstream-vue": "0.0.14-beta.3",
    "monaco-editor": "^0.55.1",
    "motion-v": "2.2.1",
    "nanoid": "^5.1.11",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.7",
    "shiki": "^4.0.2",
    "stream-markdown": "0.0.15",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "1.3.1",
    "tree-sitter-bash": "^0.25.1",
    "tw-animate-css": "1.4.0",
    "vue": "^3.5.33",
    "vue-markdown-design": "0.3.2",
    "vue-router": "^5.0.6",
    "vue-stick-to-bottom": "^1.0.0",
    "vue-stream-markdown": "^0.7.2",
    "vue-virtual-scroller": "3.0.2",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "@withfig/autocomplete": "^2.692.3",
    "@withfig/autocomplete-tools": "^2.11.0",
    "autoprefixer": "^10.5.0",
    "dpdm": "^4.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "shellcheck": "^4.1.0",
    "size-limit": "^12.1.0",
    "stylelint": "^17.10.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ]
  }
}
